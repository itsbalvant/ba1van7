# Nginx Configuration Example for Goal Tracker
# Place this in /etc/nginx/sites-available/goal-tracker
# Then create symlink: sudo ln -s /etc/nginx/sites-available/goal-tracker /etc/nginx/sites-enabled/

server {
    listen 80;
    server_name your-domain.com www.your-domain.com;
    
    # Redirect HTTP to HTTPS
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name your-domain.com www.your-domain.com;
    
    # SSL Configuration (use Let's Encrypt)
    ssl_certificate /etc/letsencrypt/live/your-domain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/your-domain.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    
    # Security Headers
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com;" always;
    
    # Root directory
    root /path/to/Track;
    index index.html;
    
    # Basic Authentication (optional - additional layer)
    # auth_basic "Goal Tracker - Authentication Required";
    # auth_basic_user_file /etc/nginx/.htpasswd;
    
    # Rate Limiting
    limit_req_zone $binary_remote_addr zone=goal_tracker:10m rate=10r/s;
    limit_req zone=goal_tracker burst=20 nodelay;
    
    # IP Whitelist (optional)
    # allow 192.168.1.0/24;
    # allow 10.0.0.0/8;
    # deny all;
    
    location / {
        # Proxy to Python server
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Or serve static files directly
        # try_files $uri $uri/ /index.html;
    }
    
    # Block access to sensitive files
    location ~ \.(py|sh|json|log)$ {
        deny all;
        return 404;
    }
    
    # Cache static files
    location ~* \.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }
    
    # Logging
    access_log /var/log/nginx/goal-tracker-access.log;
    error_log /var/log/nginx/goal-tracker-error.log;
}
